{
  "name": "notetester-learning-archive",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "prebuild": "node scripts/generate-curriculum-index.mjs && node --experimental-strip-types scripts/validate-detailed-sessions.mjs --final && node --experimental-strip-types scripts/generate-sitemap.mjs",
    "build": "vinext build",
    "start": "vinext start",
    "test": "npm run build && node --experimental-strip-types --test tests/*.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "content:validate": "node --experimental-strip-types scripts/validate-detailed-sessions.mjs",
    "content:validate:final": "node --experimental-strip-types scripts/validate-detailed-sessions.mjs --final",
    "content:coverage": "node --experimental-strip-types scripts/report-curriculum-coverage.mjs"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
